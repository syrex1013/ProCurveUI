{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020"],
    "module": "ES2020",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "noEmit": false,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "rootDir": "src",
    "baseUrl": ".",
    "outDir": "dist",
    "declaration": true,
    "sourceMap": true,
    "paths": {
      "@/*": ["src/*"],
      "@main/*": ["src/main/*"],
      "@types/*": ["src/types/*"]
    }
  },
  "include": ["src/main", "src/types"],
  "exclude": ["node_modules", "src/renderer", "src/main/preload.ts"]
}
